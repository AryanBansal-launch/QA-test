#!/usr/bin/env sh

echo "========================================="
echo "Running AI code review..."
echo "========================================="

DIFF=$(git diff @{u} HEAD)

if [ -z "$DIFF" ]; then
  echo "No changes to review."
  exit 0
fi

PROMPT="
Review this git diff.

Focus ONLY on:
- production bugs
- race conditions
- security vulnerabilities
- async issues
- TypeScript correctness
- deployment risks
- scalability concerns

Ignore formatting/style comments.

Response format:
- Severity (High/Medium/Low)
- File affected
- Issue
- Suggested fix

Be concise and actionable.

Git diff:
$DIFF
"

echo "Generating AI review..."

RESULT=$(codex exec "$PROMPT")

echo ""
echo "========================================="
echo "AI REVIEW"
echo "========================================="
echo "$RESULT"
echo "========================================="

# Save review to markdown file
cat > code_review.md <<EOF
# AI Code Review

Generated on: $(date)

## Review Result

$RESULT
EOF

echo ""
echo "Review saved to code_review.md"

# Ask user whether to continue push
echo ""
printf "Do you still want to push the code? (y/N): "
read ANSWER

case "$ANSWER" in
  y|Y )
    echo "Proceeding with push..."
    exit 0
    ;;
  * )
    echo "Push aborted. Please resolve review comments first."
    exit 1
    ;;
esac