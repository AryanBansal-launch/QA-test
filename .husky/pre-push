#!/usr/bin/env sh

echo "========================================="
echo "Running AI code review..."
echo "========================================="

# Ensure upstream branch exists
if ! git rev-parse --abbrev-ref --symbolic-full-name @{u} >/dev/null 2>&1; then
  echo "No upstream branch configured. Skipping AI review."
  exit 0
fi

# Get diff between local and upstream
DIFF=$(git diff @{u} HEAD)

if [ -z "$DIFF" ]; then
  echo "No changes to review."
  exit 0
fi

# Skip in CI/CD or when explicitly opted out
if [ "$CI" = "true" ] || [ "$SKIP_AI_REVIEW" = "true" ]; then
  echo "Skipping AI review (CI or SKIP_AI_REVIEW=true)."
  exit 0
fi

# Fail-closed when no TTY — user can't confirm the review, so block the push
# Use CI=true or SKIP_AI_REVIEW=true to opt out explicitly.
if [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
  echo "Non-interactive shell detected and no opt-out set."
  echo "Set CI=true or SKIP_AI_REVIEW=true to bypass. Push aborted."
  exit 1
fi

# Prevent huge diffs
MAX_SIZE=20000

if [ ${#DIFF} -gt $MAX_SIZE ]; then
  echo "Diff too large for AI review. Skipping."
  exit 0
fi

# Create temp prompt file
TMP_FILE=$(mktemp)

cat > "$TMP_FILE" <<EOF
Review this git diff.

Focus ONLY on:
- production bugs
- race conditions
- security vulnerabilities
- async issues
- TypeScript correctness
- deployment risks
- scalability concerns

Ignore formatting/style comments.

Response format:
- Severity (High/Medium/Low)
- File affected
- Issue
- Suggested fix

Be concise and actionable.

Git diff:
$DIFF
EOF

echo "Generating AI review..."

# Run Codex and clean noisy CLI output
if ! RESULT=$(codex exec < "$TMP_FILE" 2>&1 \
  | awk '
    /^codex$/ { capture=1; next }
    /^tokens used/ { capture=0 }
    capture
  '); then
  echo "Codex review failed."
  rm "$TMP_FILE"
  exit 1
fi

# Cleanup temp file
rm "$TMP_FILE"

echo ""
echo "========================================="
echo "AI REVIEW"
echo "========================================="
echo "$RESULT"
echo "========================================="

# Save review outside tracked git files
REVIEW_FILE=".git/code_review.md"

cat > "$REVIEW_FILE" <<EOF
# AI Code Review

Generated on: $(date)

## Review Result

$RESULT
EOF

echo ""
echo "Review saved to $REVIEW_FILE"
echo ""

# Ask user whether to continue push (TTY availability already verified above)
printf "Do you still want to push the code? (y/N): " > /dev/tty
read ANSWER < /dev/tty

case "$ANSWER" in
  y|Y )
    echo "Proceeding with push..."
    exit 0
    ;;
  * )
    echo "Push aborted. Please resolve review comments first."
    exit 1
    ;;
esac