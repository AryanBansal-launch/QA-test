#!/usr/bin/env sh

echo "Running AI code review..."

# Compare local branch against remote tracking branch
DIFF=$(git diff @{u} HEAD)

if [ -z "$DIFF" ]; then
  echo "No changes to review."
  exit 0
fi

echo "$DIFF" | codex "
Review this git diff.

Focus ONLY on:
- bugs
- race conditions
- security issues
- async mistakes
- scalability problems
- TypeScript correctness

Ignore formatting/style comments.

Be concise and actionable.
"

echo "AI review complete."