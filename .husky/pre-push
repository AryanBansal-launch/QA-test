#!/usr/bin/env sh

echo "Running AI code review..."

DIFF=$(git diff --cached)

if [ -z "$DIFF" ]; then
  echo "No staged changes."
  exit 0
fi

echo "$DIFF" | codex "
Review this git diff.

Focus on:
- bugs
- TypeScript issues
- async issues
- performance problems
- security risks
- edge cases

Be concise.
"

echo "AI review complete."